{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.8.0",
	"engines": {
		"pnpm": ">=11"
	},
	"scripts": {
		"preinstall": "node -e \"if(!(process.env.npm_config_user_agent||'').startsWith('pnpm')){console.error('\\nThis project uses pnpm. Run: corepack enable && pnpm install\\n');process.exit(1)}\"",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"phosphor-svelte": "^3.1.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
